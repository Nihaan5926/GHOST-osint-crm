# Database Configuration
DB_USER=postgres
# CRITICAL: Change this password in production! Use a strong random password.
DB_PASSWORD=changeme
DB_NAME=osint_crm_db
DB_HOST=db
DB_PORT=5432

# Application Configuration
NODE_ENV=development
PORT=3001

# Security
# CRITICAL: Set a strong SESSION_SECRET in production (minimum 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-secret-key-change-this-in-production

# Frontend URL for CORS (required in production)
FRONTEND_URL=http://localhost:8080

# Add JWT_SECRET for future authentication implementation
# JWT_SECRET=your-secret-key-here

# API Keys (if needed for external services)
# GEOCODING_API_KEY=your-api-key-here
